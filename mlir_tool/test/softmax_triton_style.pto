// Ground-truth PTO for the fused softmax kernel (Triton tutorial 02).
// Matches the structure produced by triton-to-pto-mlir from softmax_triton.mlir.
//
// Parameters (matching Triton tutorial kernel signature):
//   %arg0 = output_ptr (!pto.ptr<f32>)
//   %arg1 = input_ptr  (!pto.ptr<f32>)
//   %arg2 = input_row_stride  (i32)
//   %arg3 = output_row_stride (i32)
//   %arg4 = n_rows (i32)
//   %arg5 = n_cols (i32)
//
// BLOCK_SIZE = 256 (from tt.make_range {end=256}).
// Per-row body: tload, trowmax, tgetval, tsubs, texp, trowsum, tgetval, tdivs, tstore.
// Estimated ~245 cycles per row on A2/A3 (1x256 f32, compute-bound after MTE overlap).
module {
  func.func @softmax_kernel(%arg0: !pto.ptr<f32>, %arg1: !pto.ptr<f32>, %arg2: i32, %arg3: i32, %arg4: i32, %arg5: i32) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %0 = arith.index_cast %arg4 : i32 to index
    %1 = arith.index_cast %arg5 : i32 to index
    %2 = arith.index_cast %arg2 : i32 to index
    %3 = arith.index_cast %arg3 : i32 to index
    %4 = pto.get_block_idx
    %5 = pto.get_block_num
    %6 = arith.index_cast %4 : i64 to index
    %7 = arith.index_cast %5 : i64 to index
    %8 = pto.make_tensor_view %arg1, shape = [%0, %1] strides = [%2, %c1] : !pto.tensor_view<?x?xf32>
    %9 = pto.make_tensor_view %arg0, shape = [%0, %1] strides = [%3, %c1] : !pto.tensor_view<?x?xf32>
    %10 = pto.alloc_tile valid_row = %c1 valid_col = %1 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %11 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %12 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=1, v_row=1, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %13 = pto.alloc_tile valid_row = %c1 valid_col = %1 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %14 = pto.alloc_tile valid_row = %c1 valid_col = %1 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %15 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %16 = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=1, v_row=1, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %17 = pto.alloc_tile valid_row = %c1 valid_col = %1 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    scf.for %arg6 = %6 to %0 step %7 {
      %18 = pto.partition_view %8, offsets = [%arg6, %c0], sizes = [%c1, %1] : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<?x?xf32>
      pto.tload ins(%18 : !pto.partition_tensor_view<?x?xf32>) outs(%10 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      pto.trowmax ins(%10, %11 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%12 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=1, v_row=1, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      %19 = pto.tgetval ins(%12, %c0 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=1, v_row=1, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>, index) outs : f32
      pto.tsubs ins(%10, %19 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32) outs(%13 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      pto.texp ins(%13 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%14 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      pto.trowsum ins(%14, %15 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=1, v_col=256, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%16 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=1, v_row=1, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      %20 = pto.tgetval ins(%16, %c0 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=1, v_row=1, v_col=1, blayout=row_major, slayout=none_box, fractal=512, pad=0>, index) outs : f32
      pto.tdivs ins(%14, %20 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32) outs(%17 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      %21 = pto.partition_view %9, offsets = [%arg6, %c0], sizes = [%c1, %1] : !pto.tensor_view<?x?xf32> -> !pto.partition_tensor_view<?x?xf32>
      pto.tstore ins(%17 : !pto.tile_buf<loc=vec, dtype=f32, rows=1, cols=256, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>) outs(%21 : !pto.partition_tensor_view<?x?xf32>)
    }
    return
  }
}
